{
  "entities": {
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Publicly accessible user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "url", "description": "The user's profile picture URL." },
        "username": { "type": "string", "description": "The user's unique username." },
        "followers": { "type": "integer", "description": "Number of followers." },
        "likes": { "type": "integer", "description": "Total likes received." },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the public profile was last updated." }
      },
      "required": ["uid", "displayName"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "url", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." },
        "location": { "type": "string", "description": "The user's location." },
        "phoneNumber": { "type": "string", "description": "The user's phone number." },
        "coins": { "type": "integer", "description": "The user's coin balance." },
        "followers": { "type": "integer", "description": "Number of followers." },
        "following": { "type": "integer", "description": "Number of users followed." },
        "likes": { "type": "integer", "description": "Total likes received." }
      },
      "required": ["uid", "email", "role"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a conversation between two or more users.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the chat." },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "The UIDs of the participants in the chat." },
        "lastMessage": { "type": "string", "description": "The content of the last message sent in the chat." },
        "lastMessageTime": { "type": "string", "format": "date-time", "description": "When the last message was sent." },
        "unreadCounts": { "type": "object", "description": "A map of user UIDs to their unread message count." }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the message." },
        "chatId": { "type": "string", "description": "The ID of the chat this message belongs to." },
        "senderId": { "type": "string", "description": "The UID of the user who sent the message." },
        "text": { "type": "string", "description": "The content of the message." },
        "type": { "type": "string", "enum": ["text", "gif", "image"], "description": "The type of message." },
        "time": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "replyTo": { "type": "object", "description": "Information about the message being replied to." },
        "isEdited": { "type": "boolean", "description": "Whether the message has been edited." },
        "isRead": { "type": "boolean", "description": "Whether the message has been read." }
      },
      "required": ["chatId", "senderId", "text", "type", "time"]
    },
    "BlockedAccount": {
      "title": "Blocked Account",
      "description": "Represents a blocked relationship between two users.",
      "type": "object",
      "properties": {
        "blockerId": { "type": "string", "description": "The UID of the user who is blocking." },
        "blockedId": { "type": "string", "description": "The UID of the user who is being blocked." },
        "blockedName": { "type": "string", "description": "The name of the blocked user." },
        "blockedAvatar": { "type": "string", "format": "url", "description": "The avatar of the blocked user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the block was created." }
      },
      "required": ["blockerId", "blockedId", "createdAt"]
    },
    "CryptoAsset": {
      "title": "Crypto Asset",
      "description": "A cryptocurrency asset owned by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "symbol": { "type": "string" },
        "balance": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string", "format": "url" },
        "change24h": { "type": "number" },
        "walletAddress": { "type": "string" }
      },
      "required": ["name", "symbol", "balance"]
    },
    "Mission": {
      "title": "Mission",
      "description": "A task or achievement for a user to complete.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reward": { "type": "integer" },
        "type": { "type": "string", "enum": ["daily", "weekly", "achievement"] },
        "progress": { "type": "integer" },
        "total": { "type": "integer" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["title", "reward", "type", "userId"]
    },
    "Campaign": {
      "title": "Ad Campaign",
      "description": "A video promotion campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "packageId": { "type": "string" },
        "targetViews": { "type": "integer" },
        "currentViews": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "paused", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "videoId", "packageId", "targetViews", "status"]
    },
    "Video": {
      "title": "Video",
      "description": "A video post uploaded by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "url" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "url" },
        "description": { "type": "string" },
        "song": { "type": "string" },
        "likes": { "type": "integer" },
        "comments": { "type": "integer" },
        "shares": { "type": "integer" },
        "effect": { "type": "string" },
        "customEffectUrl": { "type": "string", "format": "url" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "author", "authorId", "description"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a video by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "videoId"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Global video posts."
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Video likes tracking."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{userId}/assets/{assetSymbol}": {
      "schema": "CryptoAsset",
      "description": "User's cryptocurrency assets."
    },
    "/users/{userId}/missions/{missionId}": {
      "schema": "Mission",
      "description": "User's missions and progress."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Global ad campaigns."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata documents."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat."
    },
    "/users/{userId}/blocked/{blockedId}": {
      "schema": "BlockedAccount",
      "description": "Blocked accounts for a specific user."
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Publicly accessible user profile information."
    }
  }
}
